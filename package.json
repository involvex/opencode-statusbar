{
	"name": "@involvex/opencode-statusbar",
	"version": "0.1.0",
	"description": "A statusbar displaying useful information",
	"keywords": [
		"opencode",
		"opencode-plugin",
		"plugin"
	],
	"license": "MIT",
	"author": "involvex <39644169+involvex@users.noreply.github.com>",
	"type": "module",
	"main": "src/index.ts",
	"files": [
		"src"
	],
	"scripts": {
		"check": "bun run format && bun run lint:fix && bun run typecheck",
		"dev": "bun run dev.ts",
		"format": "prettier . --write",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit"
	},
	"prettier": "@involvex/prettier-config",
	"dependencies": {
		"@opencode-ai/plugin": "^1.17.11",
		"@opencode-ai/sdk": "^1.17.11"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@involvex/prettier-config": "0.0.5",
		"@types/bun": "latest",
		"eslint": "^10.6.0",
		"prettier": "3.9.1",
		"typescript": "latest",
		"typescript-eslint": "^8.62.0"
	}
}
